# Python cache and virtual environments
__pycache__/
*.py[cod]
.venv/
venv/
env/

# IDE / notebook noise
.ipynb_checkpoints/
.DS_Store
Thumbs.db

# Frontend dependencies and build output
app/web/node_modules/
app/web/dist/

# Keep project structure, but ignore model artifacts
models/*/.torch-cache/
models/*/repo/**/__pycache__/
models/*/repo/**/results/**
models/*/*.pth
models/*/*.pt
models/*/*.safetensors

auxillary/*.pth
!auxillary/.gitkeep
!auxillary/README.md

models/*/weights/*
!models/*/weights/.gitkeep

models/*/checkpoints/*
!models/*/checkpoints/.gitkeep

models/*/pretrained/**
!models/*/pretrained/
!models/*/pretrained/.gitkeep

models/*/landmarks/*
!models/*/landmarks/.gitkeep

# Keep dataset folders, but ignore dataset files
data/datasets/*
!data/datasets/README.md
!data/datasets/.gitkeep

data/samples/*
!data/samples/README.md
!data/samples/.gitkeep

# Keep output folder, but ignore generated results
outputs/*
!outputs/README.md
!outputs/.gitkeep
